{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smooth Scroll",
  "version": "0.1.0",
  "identifier": "com.smoothscroll.macos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Smooth Scroll Settings",
        "label": "main",
        "width": 480,
        "height": 640,
        "resizable": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "closable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    }
  }
}
